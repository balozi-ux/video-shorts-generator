FLASK_ENV=development
FLASK_DEBUG=False

# Upload settings
UPLOAD_FOLDER=./uploads
OUTPUT_FOLDER=./outputs
TEMP_FOLDER=./temp
MAX_FILE_SIZE=5368709120

# Processing settings
USE_GPU=true
MAX_WORKERS=4

# Server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Enable features
ENABLE_SCENE_DETECTION=true
ENABLE_HIGHLIGHT_DETECTION=true
